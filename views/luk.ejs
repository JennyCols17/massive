<!DOCTYPE html>
<html lang="en" x-data="{ open: false, activeItem: {} }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUK Gallery | MassiveParts Inc.</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
        .product-card:hover img { transform: translateY(-8px) scale(1.05); }
    </style>
</head>
<body class="bg-[#f8fafc]" :class="open ? 'overflow-hidden' : ''">

    <nav class="bg-slate-900 border-b border-slate-800 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 flex h-20 items-center justify-between">
            <a href="/" class="text-2xl font-black text-white italic tracking-tighter">
                MASSIVE<span class="text-blue-500 font-light">PARTSINC.</span>
            </a>
            <a href="/brands" class="text-slate-400 hover:text-white text-sm font-bold transition-colors flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                BACK TO BRANDS
            </a>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="text-center mb-16">
            <h1 class="text-4xl font-black italic uppercase text-slate-900 tracking-tight">
                LUK <span class="text-blue-600">PRODUCTS</span>
            </h1>
            <div class="w-20 h-1.5 bg-blue-600 mx-auto mt-4 rounded-full"></div>
            <p class="text-slate-500 mt-6 text-lg">World-renowned German engineering for clutch and drivetrain systems.</p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
            
            <div @click="open = true; activeItem = { title: 'Clutch Kit Set', img: '/images/Clutch Kit Set.png', desc: 'A complete replacement solution including pressure plate and disc for restored shifting performance.' }" 
                 class="product-card cursor-pointer group">
                <div class="aspect-[4/5] bg-white rounded-2xl flex items-center justify-center p-8 border border-slate-200 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:border-blue-400">
                    <img src="/images/Clutch Kit Set.png" class="max-h-full w-full object-contain transition-all duration-500">
                </div>
                <h3 class="mt-4 text-center text-xs font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600 transition-colors">Clutch Kit Set</h3>
            </div>

            <div @click="open = true; activeItem = { title: 'Clutch Master', img: '/images/Clutch Master.png', desc: 'The primary hydraulic component that converts pedal pressure into fluid movement.' }" 
                 class="product-card cursor-pointer group">
                <div class="aspect-[4/5] bg-white rounded-2xl flex items-center justify-center p-8 border border-slate-200 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:border-blue-400">
                    <img src="/images/Clutch Master.png" class="max-h-full w-full object-contain transition-all duration-500">
                </div>
                <h3 class="mt-4 text-center text-xs font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600 transition-colors">Clutch Master</h3>
            </div>

            <div @click="open = true; activeItem = { title: 'Clutch Operating Assy', img: '/images/Clutch Operating Assy.jpg', desc: 'A precise assembly designed to engage and disengage the clutch smoothly.' }" 
                 class="product-card cursor-pointer group">
                <div class="aspect-[4/5] bg-white rounded-2xl flex items-center justify-center p-8 border border-slate-200 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:border-blue-400">
                    <img src="/images/Clutch Operating Assy.jpg" class="max-h-full w-full object-contain transition-all duration-500">
                </div>
                <h3 class="mt-4 text-center text-xs font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600 transition-colors">Clutch Operating Assy</h3>
            </div>

            <div @click="open = true; activeItem = { title: 'Clutch Release Bearing', img: '/images/Clutch Release Bearing.jpg', desc: 'Reduces friction during clutch engagement, ensuring quiet and efficient operation.' }" 
                 class="product-card cursor-pointer group">
                <div class="aspect-[4/5] bg-white rounded-2xl flex items-center justify-center p-8 border border-slate-200 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:border-blue-400">
                    <img src="/images/Clutch Release Bearing.jpg" class="max-h-full w-full object-contain transition-all duration-500">
                </div>
                <h3 class="mt-4 text-center text-xs font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600 transition-colors">Clutch Release Bearing</h3>
            </div>

            <div @click="open = true; activeItem = { title: 'Dual Mass Flywheel', img: '/images/Dual Mass Flywheel.jpg', desc: 'Reduces vibrations and noise in the drivetrain for a smoother driving experience.' }" 
                 class="product-card cursor-pointer group">
                <div class="aspect-[4/5] bg-white rounded-2xl flex items-center justify-center p-8 border border-slate-200 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:border-blue-400">
                    <img src="/images/Dual Mass Flywheel.jpg" class="max-h-full w-full object-contain transition-all duration-500">
                </div>
                <h3 class="mt-4 text-center text-xs font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600 transition-colors">Dual Mass Flywheel</h3>
            </div>

            <div @click="open = true; activeItem = { title: 'Tensioner Pulley', img: '/images/Tensioner Pulley.png', desc: 'Maintains the correct amount of tension on the drive belts to prevent slippage.' }" 
                 class="product-card cursor-pointer group">
                <div class="aspect-[4/5] bg-white rounded-2xl flex items-center justify-center p-8 border border-slate-200 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:border-blue-400">
                    <img src="/images/Tensioner Pulley.png" class="max-h-full w-full object-contain transition-all duration-500">
                </div>
                <h3 class="mt-4 text-center text-xs font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600 transition-colors">Tensioner Pulley</h3>
            </div>

        </div>
    </div>

    <div x-show="open" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center p-6">
        <div class="fixed inset-0 bg-slate-900/90 backdrop-blur-md" @click="open = false"></div>
        <div class="bg-white rounded-[2rem] overflow-hidden max-w-lg w-full relative shadow-2xl border border-slate-100"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 scale-90"
             x-transition:enter-end="opacity-100 scale-100">
            
            <button @click="open = false" class="absolute top-6 right-6 text-slate-300 hover:text-slate-900 z-10 bg-white/50 rounded-full p-1 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <div class="flex flex-col">
                <div class="bg-slate-50 p-12 flex items-center justify-center border-b border-slate-50">
                    <img :src="activeItem.img" class="max-h-64 object-contain drop-shadow-xl">
                </div>
                <div class="p-10">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="bg-blue-100 text-blue-600 text-[10px] font-black px-2 py-1 rounded uppercase tracking-widest">LuK PRODUCTS</span>
                    </div>
                    <h2 class="text-2xl font-black italic uppercase text-slate-900 leading-none" x-text="activeItem.title"></h2>
                    <p class="mt-6 text-slate-500 text-sm leading-relaxed" x-text="activeItem.desc"></p>
                    <a href="/contact" class="mt-8 block w-full bg-slate-900 text-white text-center py-4 rounded-xl font-bold text-xs tracking-[0.2em] hover:bg-blue-600 transition-all uppercase">
                        Inquire Now
                    </a>
                </div>
            </div>
        </div>
    </div>

</body>
</html>